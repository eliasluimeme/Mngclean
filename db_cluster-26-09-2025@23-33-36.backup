20250513081258	{"-- Create a simpler trigger function to handle new user creation\nCREATE OR REPLACE FUNCTION public.handle_new_user()\nRETURNS TRIGGER AS $$\nBEGIN\n  INSERT INTO public.profiles (id, email, first_name, last_name, phone)\n  VALUES (\n    new.id,\n    new.email,\n    COALESCE(new.raw_user_meta_data->>'first_name', ''),\n    COALESCE(new.raw_user_meta_data->>'last_name', ''),\n    COALESCE(new.raw_user_meta_data->>'phone', '+000000000000')\n  );\n  RETURN new;\nEND;\n$$ LANGUAGE plpgsql SECURITY DEFINER;\n\n-- Create the trigger\nDROP TRIGGER IF EXISTS on_auth_user_created ON auth.users;\nCREATE TRIGGER on_auth_user_created\n  AFTER INSERT ON auth.users\n  FOR EACH ROW EXECUTE FUNCTION public.handle_new_user();"}	create_profile_trigger	1337isloading@gmail.com	\N
20250513090757	{"-- 1. Delete all data from services\nDELETE FROM services;\n\n-- 2. Add canonical fields if not exist\nDO $$\nBEGIN\n    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='services' AND column_name='frequencies') THEN\n        ALTER TABLE services ADD COLUMN frequencies text[];\n    END IF;\n    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='services' AND column_name='prices') THEN\n        ALTER TABLE services ADD COLUMN prices jsonb;\n    END IF;\n    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='services' AND column_name='category_id') THEN\n        ALTER TABLE services ADD COLUMN category_id text;\n    END IF;\nEND $$;"}	reset_services_table	1337isloading@gmail.com	\N
20250513090808	{"INSERT INTO services (id, title, category_id, frequencies, prices, description, icon, image, gradient)\nVALUES\n  ('nettoyage_maison', 'Nettoyage Maison', 'residential', ARRAY['one-time', 'bi-weekly', 'monthly'], '{\\"one-time\\": 100, \\"bi-weekly\\": 80, \\"monthly\\": 70}', 'Nettoyage de maison complet', 'home', '../../assets/images/home1.jpg', '[\\"#3B82F6\\",\\"#2563EB\\"]'),\n  ('nettoyage_bureaux', 'Nettoyage de Bureaux', 'office', ARRAY['one-time', 'bi-weekly', 'monthly'], '{\\"one-time\\": 120, \\"bi-weekly\\": 100, \\"monthly\\": 90}', 'Nettoyage de bureaux professionnel', 'office-building', '../../assets/images/bureau1.jpg', '[\\"#6366F1\\",\\"#4F46E5\\"]'),\n  ('nettoyage_commercial', 'Nettoyage Commercial', 'commercial', ARRAY['one-time', 'bi-weekly', 'monthly'], '{\\"one-time\\": 150, \\"bi-weekly\\": 130, \\"monthly\\": 110}', 'Nettoyage commercial', 'store', '../../assets/images/bureau1.jpg', '[\\"#8B5CF6\\",\\"#7C3AED\\"]'),\n  ('apres_construction', 'Après Construction', 'specialized', ARRAY['one-time'], '{\\"one-time\\": 200}', 'Nettoyage après construction', 'tool', '../../assets/images/chantier.jpg', '[\\"#EC4899\\",\\"#D946EF\\"]'),\n  ('demande_devis', 'Demande de Devis', 'specialized', ARRAY['one-time'], '{\\"one-time\\": 0}', 'Service sur devis', 'edit', '../../assets/images/chantier.jpg', '[\\"#EC4899\\",\\"#D946EF\\"]'),\n  ('nettoyage_canapes', 'Nettoyage Canapés', 'furniture', ARRAY['one-time'], '{\\"one-time\\": 150}', 'Nettoyage professionnel de canapés', 'sofa', '../../assets/images/tapis1.jpg', '[\\"#F59E0B\\",\\"#D97706\\"]'),\n  ('nettoyage_matelas', 'Nettoyage Matelas', 'furniture', ARRAY['one-time'], '{\\"one-time\\": 120}', 'Nettoyage matelas', 'bed', '../../assets/images/tapis1.jpg', '[\\"#F59E0B\\",\\"#D97706\\"]'),\n  ('nettoyage_tapis', 'Nettoyage Tapis', 'furniture', ARRAY['one-time'], '{\\"one-time\\": 100}', 'Nettoyage tapis', 'grid', '../../assets/images/tapis1.jpg', '[\\"#F59E0B\\",\\"#D97706\\"]');"}	insert_canonical_services	1337isloading@gmail.com	\N
20250513091044	{"DELETE FROM service_categories;\n\nINSERT INTO service_categories (service_id, category_id) VALUES\n  ('nettoyage_maison', 'residential'),\n  ('nettoyage_bureaux', 'office'),\n  ('nettoyage_commercial', 'commercial'),\n  ('apres_construction', 'specialized'),\n  ('demande_devis', 'specialized'),\n  ('nettoyage_canapes', 'furniture'),\n  ('nettoyage_matelas', 'furniture'),\n  ('nettoyage_tapis', 'furniture');"}	populate_service_categories_canonical	1337isloading@gmail.com	\N
20250514020438	{"UPDATE services SET prices = '{\n  \\"monthly\\": {\\"standard\\": 70, \\"intensif\\": 80},\n  \\"one-time\\": {\\"standard\\": 100, \\"intensif\\": 110},\n  \\"bi-weekly\\": {\\"standard\\": 80, \\"intensif\\": 90}\n}' WHERE title = 'Nettoyage Maison';\n\nUPDATE services SET prices = '{\n  \\"monthly\\": {\\"standard\\": 90, \\"intensif\\": 100},\n  \\"one-time\\": {\\"standard\\": 120, \\"intensif\\": 130},\n  \\"bi-weekly\\": {\\"standard\\": 100, \\"intensif\\": 110}\n}' WHERE title = 'Nettoyage de Bureaux';\n\nUPDATE services SET prices = '{\n  \\"monthly\\": {\\"standard\\": 110, \\"intensif\\": 120},\n  \\"one-time\\": {\\"standard\\": 150, \\"intensif\\": 160},\n  \\"bi-weekly\\": {\\"standard\\": 130, \\"intensif\\": 140}\n}' WHERE title = 'Nettoyage Commercial';"}	update_prices_field_for_main_services	1337isloading@gmail.com	\N
20250514025322	{"CREATE TABLE public.addresses (\n  id uuid PRIMARY KEY DEFAULT uuid_generate_v4(),\n  user_id uuid NOT NULL,\n  tag text NOT NULL,\n  street text NOT NULL,\n  city text NOT NULL,\n  state text,\n  zip_code text,\n  country text NOT NULL,\n  is_default boolean DEFAULT false,\n  latitude double precision,\n  longitude double precision,\n  full_address text,\n  created_at timestamptz DEFAULT now(),\n  updated_at timestamptz DEFAULT now(),\n  CONSTRAINT addresses_user_id_fkey FOREIGN KEY (user_id) REFERENCES public.profiles(id)\n);\nCOMMENT ON TABLE public.addresses IS 'Stores user addresses with relationship to profiles table.';"}	create_addresses_table	1337isloading@gmail.com	\N
20250514055030	{"CREATE TABLE public.orders (\n  id uuid PRIMARY KEY DEFAULT uuid_generate_v4(),\n  user_id uuid NOT NULL,\n  service_id text,\n  service_title text,\n  selected_frequency text,\n  abonnement boolean,\n  visit_services_detailed jsonb,\n  surface text,\n  dates jsonb,\n  time text,\n  address text,\n  addons jsonb,\n  total_price numeric,\n  base_price numeric,\n  price_breakdown jsonb,\n  images jsonb,\n  notes text,\n  status text DEFAULT 'pending',\n  order_number text UNIQUE,\n  created_at timestamptz DEFAULT now()\n);"}	create_orders_table	1337isloading@gmail.com	\N
20250519012447	{"UPDATE public.orders\nSET visit_services_detailed = (\n  SELECT jsonb_agg(\n    jsonb_set(\n      jsonb_set(\n        jsonb_set(\n          elem, \n          '{date}', \n          to_jsonb(dates ->> ((idx - 1)::text))\n        ),\n        '{time}',\n        to_jsonb(orders.time)\n      ),\n      '{completed}',\n      'false'::jsonb\n    )\n  )\n  FROM (\n    SELECT\n      arr.elem,\n      arr.idx,\n      o.dates::jsonb AS dates\n    FROM\n      orders o,\n      LATERAL jsonb_array_elements(o.visit_services_detailed) WITH ORDINALITY arr(elem, idx)\n    WHERE o.id = orders.id\n  ) dates_arr\n)\nWHERE visit_services_detailed IS NOT NULL AND dates IS NOT NULL AND time IS NOT NULL;"}	add_date_time_completed_to_visit_services_detailed_final	1337isloading@gmail.com	\N
20250520021355	{"CREATE TABLE public.teams (\n  id uuid PRIMARY KEY DEFAULT uuid_generate_v4(),\n  name text NOT NULL,\n  description text,\n  created_at timestamptz NOT NULL DEFAULT now()\n);\n\n-- Join table for team members (staff)\nCREATE TABLE public.team_members (\n  team_id uuid REFERENCES public.teams(id) ON DELETE CASCADE,\n  user_id uuid REFERENCES public.profiles(id) ON DELETE CASCADE,\n  added_at timestamptz NOT NULL DEFAULT now(),\n  PRIMARY KEY (team_id, user_id)\n);\n\n-- Only users with staff=true in profiles should be added to team_members (enforced at application level)\n"}	add_teams_table	1337isloading@gmail.com	\N
\.


